		"@types/react-dom": "~19.2.3",
		"typescript": "6.0.3"
	},
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"listUnknownPackages": false,
				"exclude": [
					"@gorhom/portal"
				]
			}
		},
		"install": {
			"exclude": [
				"react-native-get-random-values"
			]
		}
	},
	"patchedDependencies": {
		"@videojs/core@10.0.0-beta.25": "patches/@videojs%2Fcore@10.0.0-beta.25.patch"
	}
