{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"types": ["vite/client", "chromecast-caf-receiver"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"resolveJsonModule": true
	},
	"include": ["src", "vite.config.ts"]
}
